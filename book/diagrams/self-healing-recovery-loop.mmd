flowchart LR
  Goal["Goal, constraints, budgets"] --> Step["Choose next workflow step"]
  Step --> Execute["Execute validated action"]
  Execute --> Observe["Observe result, error, and side effects"]
  Observe --> Classify{"Failure classified?"}
  Classify -->|"No failure"| Continue{"More work?"}
  Continue -->|"Yes"| Step
  Continue -->|"No"| Done["Completed workflow"]
  Classify -->|"Transient"| Retry{"Retry safe and budget left?"}
  Retry -->|"Yes"| Execute
  Retry -->|"No"| Fallback["Use fallback path"]
  Classify -->|"Bad plan"| Replan["Re-plan with new evidence"]
  Classify -->|"Side effect risk"| Compensate["Compensate or pause side effects"]
  Fallback --> Continue
  Replan --> Step
  Compensate --> Escalate["Escalate to human or operator"]
  Escalate --> Stop["Stopped with reason and recovery state"]
  Done --> Trace["Trace actions, retries, failures, recovery decisions"]
  Stop --> Trace
