flowchart LR
  Goal["Goal, constraints, budget"] --> Planner["Planner proposes ordered steps"]
  Planner --> Review{"Plan valid?"}
  Review -->|"No"| Revise["Revise plan or ask"]
  Revise --> Planner
  Review -->|"Yes"| Queue["Executable step queue"]
  Queue --> Step{"Next step allowed?"}
  Step -->|"No"| Escalate["Escalate, refuse, or replan"]
  Step -->|"Yes"| Execute["Executor runs validated step"]
  Execute --> Observe["Observe result and errors"]
  Observe --> Update["Update progress, budget, trace"]
  Update --> Done{"Goal complete or stop hit?"}
  Done -->|"No"| Queue
  Done -->|"Replan needed"| Planner
  Done -->|"Yes"| Output["Final result"]
  Output --> Audit["Trace plan, steps, observations, stop reason"]
  Escalate --> Audit
