flowchart LR
  Runs["Run logs, eval failures, reviewer feedback"] --> Mine["Mine improvement candidates"]
  Mine --> Proposal["Propose versioned change"]
  Proposal --> Target["Prompt, tool, retrieval, policy, test, or skill"]
  Target --> Evals{"Regression evals pass?"}
  Evals -->|"No"| Reject["Reject or revise"]
  Reject --> Mine
  Evals -->|"Yes"| Approval{"Approval gate"}
  Approval -->|"Denied"| Reject
  Approval -->|"Approved"| Rollout["Canary or staged rollout"]
  Rollout --> Monitor{"Metrics safe?"}
  Monitor -->|"No"| Rollback["Rollback and add regression case"]
  Monitor -->|"Yes"| Promote["Promote new version"]
  Rollback --> Mine
  Promote --> Audit["Version history, rationale, eval evidence"]
  Reject --> Audit
