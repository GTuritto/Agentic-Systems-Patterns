flowchart LR
  Goal["User goal"] --> Fit{"Safer interface exists?"}
  Fit -->|"API, MCP, DB, workflow"| Tool["Use typed tool or workflow"]
  Fit -->|"UI is only practical path"| Observe["Observe only"]
  Observe --> Evidence{"Observation evidence complete?"}
  Evidence -->|"No"| Stop["Stop or ask human"]
  Evidence -->|"Yes"| Tier{"Required action tier"}
  Tier -->|"Read screen or DOM"| Observe
  Tier -->|"Known selector"| Guided["Guided action"]
  Tier -->|"Bounded form"| Form["Form completion"]
  Tier -->|"File in sandbox"| File["Sandboxed file workflow"]
  Tier -->|"Logged-in app"| Auth["Authenticated operation"]
  Guided --> Gate{"High-risk action?"}
  Form --> Gate
  File --> Gate
  Auth --> Gate
  Gate -->|"No"| Execute["Validate precondition, execute, check postcondition"]
  Gate -->|"Yes"| Visual["Visual confirmation gate"]
  Visual --> Approval{"Approved exact action?"}
  Approval -->|"No"| Stop
  Approval -->|"Yes"| Execute
  Execute --> Result{"Postcondition passed?"}
  Result -->|"Yes"| Trace["Store trace and artifact policy"]
  Result -->|"No"| Recover["Narrow recovery playbook"]
  Recover --> Stop
