flowchart LR
  Goal["Shared goal and acceptance criteria"] --> Split{"Work independent?"}
  Split -->|"No"| Sequential["Use sequential workflow or supervisor"]
  Split -->|"Yes"| Fanout["Fan out scoped tasks"]
  Fanout --> A["Agent A"]
  Fanout --> B["Agent B"]
  Fanout --> C["Agent C"]
  A --> Join["Fan in outputs, evidence, cost, latency"]
  B --> Join
  C --> Join
  Join --> Compare{"Results compatible?"}
  Compare -->|"No"| Resolve["Resolve conflict, rerun, or escalate"]
  Compare -->|"Yes"| Merge["Merge, rank, or synthesize"]
  Resolve --> Merge
  Merge --> Accept{"Owner accepts?"}
  Accept -->|"No"| Resolve
  Accept -->|"Yes"| Output["Accepted result"]
  Output --> Audit["Trace per-agent inputs, outputs, merge decision"]
  Sequential --> Audit
  Resolve --> Audit
