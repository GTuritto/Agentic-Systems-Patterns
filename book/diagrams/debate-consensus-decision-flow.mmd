flowchart LR
  Goal["Shared question and acceptance criteria"] --> Positions["Independent proposals"]
  Positions --> A["Agent A answer and evidence"]
  Positions --> B["Agent B answer and evidence"]
  Positions --> C["Agent C answer and evidence"]
  A --> Critique["Cross-critique claims, gaps, and assumptions"]
  B --> Critique
  C --> Critique
  Critique --> Score["Judge scores evidence, tests, and policy fit"]
  Score --> Agreement{"Strong agreement?"}
  Agreement -->|"Yes"| Synthesize["Synthesize answer with cited evidence"]
  Agreement -->|"No"| Dissent["Record dissent and unresolved risks"]
  Dissent --> Decision{"Can owner decide?"}
  Decision -->|"No"| Escalate["Escalate, gather more evidence, or rerun"]
  Decision -->|"Yes"| Synthesize
  Escalate --> Positions
  Synthesize --> Accept{"Final owner accepts?"}
  Accept -->|"No"| Escalate
  Accept -->|"Yes"| Output["Accepted answer"]
  Output --> Audit["Trace proposals, critiques, votes, dissent, and decision rule"]
