flowchart LR
  Event["Webhook, queue, schedule, or domain event"] --> Ingest["Ingest with event id and idempotency key"]
  Ingest --> Dedupe{"Duplicate or stale?"}
  Dedupe -->|"Yes"| Ack["Acknowledge without side effects"]
  Dedupe -->|"No"| Context["Load state, policy, memory, and config"]
  Context --> Gate{"Policy and context sufficient?"}
  Gate -->|"No"| Escalate["Reject, hold, or request human review"]
  Gate -->|"Yes"| Execute["Run bounded agent or workflow step"]
  Execute --> Checkpoint["Checkpoint result, trace, cost, and error state"]
  Checkpoint --> Result{"Step outcome"}
  Result -->|"Success"| Publish["Publish side effect or next event"]
  Result -->|"Retryable failure"| Retry["Retry with backoff and budget"]
  Result -->|"Permanent failure"| DeadLetter["Dead-letter with replay data"]
  Retry --> Execute
  Publish --> Audit["Audit trail and regression replay set"]
  DeadLetter --> Audit
  Escalate --> Audit
  Ack --> Audit
