{
  "name": "agentic-systems-patterns-book",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vitepress dev docs",
    "manifest:test": "node scripts/book-manifest.spec.mjs",
    "diagrams": "node scripts/generate-diagrams.mjs",
    "content": "node scripts/generate-pattern-pages.mjs",
    "build": "npm run diagrams && npm run content && vitepress build docs",
    "serve": "vitepress preview docs",
    "clear": "rm -rf docs/.vitepress/cache docs/.vitepress/dist",
    "pdf": "npm run diagrams && npm run content && node scripts/generate-pdf.mjs"
  },
  "devDependencies": {
    "markdown-it": "^14.1.0",
    "playwright": "^1.57.0",
    "vitepress": "^1.6.4"
  },
  "overrides": {
    "vite": "6.4.3"
  }
}
