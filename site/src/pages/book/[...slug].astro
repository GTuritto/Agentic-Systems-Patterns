---
import BookLayout from '../../layouts/BookLayout.astro';
import { chapterNavigation, relatedChapters, siteBase, siteChapters } from '../../lib/book-manifest';
import { renderChapter } from '../../lib/markdown';

export function getStaticPaths() {
  return siteChapters.map(chapter => ({
    params: { slug: chapter.slug },
    props: { chapter }
  }));
}

const { chapter } = Astro.props;
const rendered = await renderChapter(chapter);
const navigation = chapterNavigation(chapter.slug);
const related = relatedChapters(chapter.slug);
---

<BookLayout title={`${rendered.title} | Agentic Systems Patterns`} currentSlug={chapter.slug}>
  <article set:html={rendered.html} />
  {related.length > 0 && (
    <section class="related-chapters" aria-labelledby="related-chapters-title">
      <p class="eyebrow">Continue exploring</p>
      <h2 id="related-chapters-title">Related chapters</h2>
      <div class="related-chapter-grid">
        {related.map(item => (
          <a class="related-chapter-card" href={`${siteBase}/book/${item.slug}/`}>
            <span>{item.sectionId.replaceAll('-', ' ')}</span>
            <strong>{item.title}</strong>
          </a>
        ))}
      </div>
    </section>
  )}
  <nav class="chapter-pagination" aria-label="Chapter navigation">
    {navigation.previous ? (
      <a class="page-link page-link--previous" href={`${siteBase}/book/${navigation.previous.slug}/`}>
        <span>Previous</span>
        <strong>{navigation.previous.title}</strong>
      </a>
    ) : <span></span>}
    {navigation.next ? (
      <a class="page-link page-link--next" href={`${siteBase}/book/${navigation.next.slug}/`}>
        <span>Next</span>
        <strong>{navigation.next.title}</strong>
      </a>
    ) : <span></span>}
  </nav>
</BookLayout>
