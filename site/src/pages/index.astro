---
import BookLayout from '../layouts/BookLayout.astro';
import { chaptersForSection, sectionDescriptions, siteBase, siteChapters, siteSections } from '../lib/book-manifest';

const firstChapter = siteChapters[0];
const sectionsWithChapters = siteSections
  .map(section => ({ ...section, chapters: chaptersForSection(section.id) }))
  .filter(section => section.chapters.length > 0);
const featuredSections = sectionsWithChapters.slice(0, 6);
---

<BookLayout title="Agentic Systems Patterns">
  <section class="hero">
    <p class="eyebrow">Online-first field guide</p>
    <h1>Agentic Systems Patterns</h1>
    <p class="lede">A practical book for designing, evaluating, and operating agentic systems: goals, loops, tools, skills, memory, protocols, multi-agent topologies, and production runtimes.</p>
    <div class="hero-actions">
      <a class="button button-primary" href={`${siteBase}/book/${firstChapter.slug}/`}>Start reading</a>
      <a class="button button-secondary" href={`${siteBase}/patterns/`}>Browse patterns</a>
      <a class="button button-secondary" href="#sections">Browse sections</a>
    </div>
  </section>

  <section class="stats-panel" aria-label="Book status">
    <div>
      <strong>{siteChapters.length}</strong>
      <span>chapters</span>
    </div>
    <div>
      <strong>{sectionsWithChapters.length}</strong>
      <span>sections</span>
    </div>
    <div>
      <strong>Static</strong>
      <span>searchable site</span>
    </div>
  </section>

  <section id="sections" class="section-grid">
    <div class="section-heading">
      <p class="eyebrow">Reading paths</p>
      <h2>Browse the book</h2>
    </div>
    <div class="cards">
      {featuredSections.map(section => (
        <article class="section-card">
          <span>{section.chapters.length} chapters</span>
          <h3>{section.title}</h3>
          <p>{sectionDescriptions.get(section.id)}</p>
          <a href={`${siteBase}/sections/${section.id}/`}>Open section</a>
        </article>
      ))}
    </div>
  </section>
</BookLayout>
