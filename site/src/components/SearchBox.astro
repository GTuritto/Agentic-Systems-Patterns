---
import { chapterSearchExcerpt, siteChapters, siteSections } from '../lib/book-manifest.ts';
import { bookHref, localizedBase, type Language } from '../lib/i18n.ts';

const { language = 'en' } = Astro.props;
const currentLanguage = language as Language;
const currentBase = localizedBase(currentLanguage);
const sectionTitle = new Map(siteSections.map(section => [section.id, section.title]));
const levelFilters = [...new Set(siteChapters.map(chapter => chapter.difficulty))];
const typeFilters = [...new Set(siteChapters.map(chapter => chapter.type))];
const fallbackSearchItems = siteChapters.map(chapter => ({
  title: chapter.title,
  url: bookHref(currentLanguage, chapter.slug),
  excerpt: chapterSearchExcerpt(chapter),
  section: sectionTitle.get(chapter.sectionId) ?? chapter.sectionId,
  type: chapter.type,
  level: chapter.difficulty,
  effort: chapter.effort,
  readerPaths: chapter.readerPaths,
  searchText: `${chapter.title} ${chapter.type} ${chapter.difficulty} ${chapter.effort} ${chapter.readerPaths.join(' ')} ${chapterSearchExcerpt(chapter)}`
}));
---

<form class="search" role="search">
  <label for="search-input">Search book</label>
  <div class="search-input-row">
    <input
      id="search-input"
      type="search"
      placeholder="Search chapters..."
      autocomplete="off"
      aria-controls="search-results"
      aria-expanded="false"
    />
    <button type="submit">Search</button>
  </div>
  <div class="search-filter-row" aria-label="Search filters">
    <label for="search-level-filter">
      <span>Level</span>
      <select id="search-level-filter">
        <option value="">All levels</option>
        {levelFilters.map(level => <option value={level}>{level}</option>)}
      </select>
    </label>
    <label for="search-type-filter">
      <span>Type</span>
      <select id="search-type-filter">
        <option value="">All types</option>
        {typeFilters.map(type => <option value={type}>{type}</option>)}
      </select>
    </label>
  </div>
  <div id="search-status" aria-live="polite"></div>
  <div id="search-results" role="listbox" aria-label="Search results"></div>
</form>

<script id="search-fallback-data" type="application/json" set:html={JSON.stringify(fallbackSearchItems)}></script>

<script define:vars={{ currentBase }}>
  const input = document.querySelector('#search-input');
  const form = document.querySelector('.search');
  const levelFilter = document.querySelector('#search-level-filter');
  const typeFilter = document.querySelector('#search-type-filter');
  const results = document.querySelector('#search-results');
  const status = document.querySelector('#search-status');
  const pagefindPath = '/Agentic-Systems-Patterns/pagefind/pagefind.js';
  const pagefindBase = currentBase.replace(/\/es$/, '');
  let activeIndex = -1;

  async function loadPagefind() {
    const pagefind = await import(/* @vite-ignore */ pagefindPath);
    await pagefind.options({ baseUrl: `${pagefindBase}/` });
    return pagefind;
  }

  let pagefindPromise;
  let searchRun = 0;

  function setStatus(message) {
    if (status) status.textContent = message;
  }

  function clearResults() {
    activeIndex = -1;
    if (results) results.innerHTML = '';
    input?.setAttribute('aria-expanded', 'false');
    setStatus('');
  }

  function resultLinks() {
    return Array.from(results?.querySelectorAll('.search-result') ?? []);
  }

  function setActiveResult(index) {
    const links = resultLinks();
    if (links.length === 0) return;
    activeIndex = (index + links.length) % links.length;
    links.forEach((link, linkIndex) => {
      link.classList.toggle('is-active', linkIndex === activeIndex);
      link.setAttribute('aria-selected', linkIndex === activeIndex ? 'true' : 'false');
    });
    links[activeIndex].focus();
  }

  function escapeHtml(value) {
    return value
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;');
  }

  function normalizeUrl(url) {
    if (url.startsWith('/Agentic-Systems-Patterns/')) return url;
    if (url.startsWith('/es/')) return `${pagefindBase}${url}`;
    if (url.startsWith('/')) return `${currentBase}${url}`;
    return `${currentBase}/${url}`;
  }

  function activeFilters() {
    return {
      level: levelFilter?.value || undefined,
      type: typeFilter?.value || undefined
    };
  }

  function pagefindSearchOptions(filters) {
    const pagefindFilters = {};
    if (filters.level) pagefindFilters.level = filters.level;
    if (filters.type) pagefindFilters.type = filters.type;
    return Object.keys(pagefindFilters).length > 0 ? { filters: pagefindFilters } : undefined;
  }

  function fallbackSearch(q, filters) {
    const data = document.querySelector('#search-fallback-data');
    const items = data?.textContent ? JSON.parse(data.textContent) : [];
    const normalizedQuery = q.toLowerCase();
    return items
      .filter(item => {
        const matchesQuery = (item.searchText ?? `${item.title} ${item.excerpt}`).toLowerCase().includes(normalizedQuery);
        const matchesLevel = !filters.level || item.level === filters.level;
        const matchesType = !filters.type || item.type === filters.type;
        return matchesQuery && matchesLevel && matchesType;
      })
      .slice(0, 6);
  }

  function renderItems(items) {
    results.innerHTML = items.map((item, index) => {
      const title = escapeHtml(item.title ?? 'Untitled chapter');
      const excerpt = item.excerpt ? escapeHtml(item.excerpt.replace(/<[^>]+>/g, '')) : 'Open this chapter from the search results.';
      const tags = [item.section, item.type, item.level]
        .filter(Boolean)
        .map(tag => `<span>${escapeHtml(tag)}</span>`)
        .join('');
      return `
        <a class="search-result" href="${normalizeUrl(item.url)}" role="option" aria-selected="false" tabindex="${index === 0 ? '0' : '-1'}">
          <span class="search-result-title">${title}</span>
          ${tags ? `<span class="search-result-tags">${tags}</span>` : ''}
          <span class="search-result-excerpt">${excerpt}</span>
        </a>
      `;
    }).join('');
  }

  async function runSearch() {
    const q = input?.value.trim() ?? '';
    const filters = activeFilters();
    if (!results) return;
    if (!q) {
      clearResults();
      return;
    }

    const run = ++searchRun;
    input.setAttribute('aria-expanded', 'true');
    results.innerHTML = '<div class="search-message">Searching...</div>';
    setStatus('Searching...');

    try {
      pagefindPromise ??= loadPagefind();
      const pagefind = await pagefindPromise;
      const search = await pagefind.search(q, pagefindSearchOptions(filters));
      if (run !== searchRun) return;

      if (search.results.length === 0) {
        results.innerHTML = '<div class="search-message">No matches. Try a broader term or filter.</div>';
        setStatus('No search results found.');
        return;
      }

      const items = await Promise.all(search.results.slice(0, 6).map(result => result.data()));
      if (run !== searchRun) return;

      renderItems(items.map(item => ({
        title: item.meta?.title ?? 'Untitled chapter',
        excerpt: item.meta?.description ?? item.excerpt,
        url: item.url,
        section: item.meta?.section,
        type: item.meta?.type,
        level: item.meta?.level
      })));
      setStatus(`${items.length} search results shown.`);
    } catch {
      const items = fallbackSearch(q, filters);
      if (run !== searchRun) return;
      if (items.length === 0) {
        results.innerHTML = '<div class="search-message">No matches. Try a broader term or filter.</div>';
        setStatus('No search results found.');
        return;
      }
      renderItems(items);
      setStatus(`${items.length} fallback search results shown.`);
    }
  }

  form?.addEventListener('submit', event => {
    event.preventDefault();
    runSearch();
  });
  input?.addEventListener('input', runSearch);
  levelFilter?.addEventListener('change', runSearch);
  typeFilter?.addEventListener('change', runSearch);

  input?.addEventListener('keydown', event => {
    if (event.key === 'ArrowDown') {
      event.preventDefault();
      setActiveResult(0);
    }
    if (event.key === 'Escape') {
      clearResults();
      input.value = '';
    }
  });

  results?.addEventListener('keydown', event => {
    if (event.key === 'ArrowDown') {
      event.preventDefault();
      setActiveResult(activeIndex + 1);
    }
    if (event.key === 'ArrowUp') {
      event.preventDefault();
      setActiveResult(activeIndex - 1);
    }
    if (event.key === 'Escape') {
      clearResults();
      input?.focus();
    }
  });
</script>

<style>
  .search {
    border-top: 1px solid var(--border);
    margin-top: 22px;
    padding-top: 18px;
  }

  .search-input-row {
    display: grid;
    gap: 7px;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  label {
    display: block;
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  input {
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    box-sizing: border-box;
    color: var(--text);
    font: 0.9rem var(--font-ui);
    padding: 10px 13px;
    width: 100%;
  }

  button {
    background: var(--nav);
    border: 1px solid var(--nav);
    border-radius: 999px;
    color: var(--on-nav);
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 850;
    padding: 0 12px;
  }

  button:hover {
    background: var(--accent-dark);
    border-color: var(--accent-dark);
  }

  .search-filter-row {
    display: grid;
    gap: 8px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 9px;
  }

  .search-filter-row label {
    display: grid;
    gap: 5px;
    margin: 0;
  }

  .search-filter-row span {
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.62rem;
    font-weight: 820;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .search-filter-row select {
    appearance: none;
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--nav);
    font: 0.78rem var(--font-ui);
    max-width: 100%;
    min-width: 0;
    padding: 8px 9px;
    width: 100%;
  }

  #search-results {
    display: grid;
    gap: 7px;
    font-family: var(--font-ui);
    font-size: 0.84rem;
    margin-top: 12px;
  }

  #search-status {
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.74rem;
    margin-top: 8px;
    min-height: 1em;
  }

  #search-results :global(.search-result) {
    background: var(--sidebar-hover);
    border: 1px solid transparent;
    border-radius: 8px;
    color: var(--nav);
    display: grid;
    gap: 4px;
    padding: 9px 10px;
    text-decoration: none;
  }

  #search-results :global(.search-result:hover),
  #search-results :global(.search-result.is-active),
  #search-results :global(.search-result:focus-visible) {
    background: var(--input-bg);
    border-color: var(--accent);
  }

  #search-results :global(.search-result-title) {
    font-weight: 850;
    line-height: 1.25;
  }

  #search-results :global(.search-result-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  #search-results :global(.search-result-tags span) {
    background: var(--tag-bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--nav);
    font-size: 0.62rem;
    font-weight: 820;
    line-height: 1;
    padding: 4px 6px;
  }

  #search-results :global(.search-result-excerpt) {
    color: var(--muted);
    font-size: 0.76rem;
    line-height: 1.35;
  }

  #search-results :global(.search-message) {
    background: var(--panel-glass);
    border: 1px dashed var(--border);
    border-radius: 8px;
    color: var(--muted);
    padding: 10px;
  }
</style>
